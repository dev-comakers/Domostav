# Copy to `.env` and adjust for your environment.
# The app reads these via python-dotenv on startup.

# Local development (docker-compose up -d)
DATABASE_URL=postgresql://domostav_app:domostav_dev_password@127.0.0.1:5432/domostav

# Production (on the server itself — connect via localhost, not the public IP):
# DATABASE_URL=postgresql://domostav_app:STRONG_SECRET@127.0.0.1:5432/domostav
#
# Public server for reference: 91.99.229.161 (user: dimacomakers, service: domostav.service)
# Do NOT expose 5432 to the public internet; keep Postgres bound to localhost.

# Optional: LLM keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
